{
  "name": "lew-ui",
  "type": "module",
  "version": "2.8.2",
  "description": "A Component Library for Vue3.js.",
  "author": "lewkamtao",
  "license": "MIT",
  "keywords": [
    "vue3",
    "components",
    "ui library",
    "frontend"
  ],
  "sideEffects": [
    "*.css",
    "*.scss",
    "dist/index.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style": "./dist/index.css"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "engines": {
    "node": "^22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build:docs": "pnpm lint:fix && pnpm lint:css:fix && node scripts/extract-types.js && vue-tsc --noEmit && vite build -c vite.config.docs.ts",
    "build:lib": "vue-tsc --noEmit && vite build -c vite.config.lib.ts",
    "version:patch": "node ./bump-version.js",
    "analyze": "ANALYZE=true vite build -c vite.config.lib.ts",
    "format": "pnpm lint:fix && pnpm lint:css:fix && node scripts/extract-types.js",
    "format:types": "node scripts/extract-types.js",
    "sort:types": "node scripts/sort-components.js",
    "lint:css": "stylelint \"lib/**/*.{css,scss}\" \"docs/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"lib/**/*.{css,scss}\" \"docs/**/*.{css,scss}\" --fix",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.3"
  },
  "dependencies": {
    "@vueuse/core": "^13.5.0",
    "csstype": "^3.1.3",
    "dayjs": "^1.11.13",
    "expr-eval": "^2.0.2",
    "lodash-es": "^4.17.21",
    "lucide-vue-next": "^0.534.0",
    "tippy.js": "^6.3.7",
    "vue-i18n": "^11.1.0",
    "vue-virt-list": "^1.5.11",
    "yup": "^1.2.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.16.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "axios": "^1.6.7",
    "eslint": "^9.31.0",
    "eslint-plugin-format": "^1.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jsdom": "^26.1.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass": "^1.89.2",
    "shiki-code-block-vue": "0.0.6-beta.1",
    "stylelint": "16.2.1",
    "stylelint-config-rational-order": "0.1.2",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "ts-morph": "^26.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "unplugin-auto-import": "^20.3.0",
    "vite": "8.0.0-beta.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-zip-pack": "^1.2.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.17",
    "vue-router": "^4.0.13",
    "vue-tsc": "^3.0.1",
    "vuedraggable": "^4.1.0"
  }
}
